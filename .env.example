# =========================================================
# PLC Casa de Máquinas 1B
# =========================================================
MODBUS_HOST=192.168.6.100
MODBUS_PORT=502
MODBUS_UNIT_ID=1
MODBUS_TIMEOUT_MS=2000

# =========================================================
# Direcciones Modbus (referencia 0:xxxxx = coils)
# Si tu PLC usa direccionamiento 1-based, deja COIL_OFFSET=0.
# Si la documentación es 1-based y necesitas restar 1 en el cable,
# pon COIL_OFFSET=-1.
# =========================================================
COIL_ON=25
COIL_OFF=26
COIL_STATUS=16
COIL_OFFSET=0

# Cómo leer el coil de estado:
#   1 = como coil (FC1, readCoils)
#   2 = como discrete input (FC2, readDiscreteInputs)
# En muchos PLCs la dirección documentada "0:0016" es un coil (FC1), pero
# en otros el feedback de salida está en el espacio de inputs (FC2).
# Si la lectura siempre queda en false aunque hayas mandado un pulso ON,
# prueba a cambiar este valor a 2.
STATUS_READ_FC=1

# Duración del pulso momentáneo en milisegundos
# (cuánto tiempo se mantiene en 1 antes de volver a 0)
# Súbelo si el PLC tiene scan lento (500-1000 ms es seguro)
PULSE_MS=500

# Logs detallados de cada operación Modbus en consola
MODBUS_DEBUG=false

# =========================================================
# Horario por defecto (formato HH:MM 24h)
# Editables luego desde la UI web. Se persisten en data/schedule.json
# =========================================================
SCHEDULE_ON=17:30
SCHEDULE_OFF=06:00
SCHEDULE_ENABLED=true
SCHEDULE_TIMEZONE=America/Guatemala

# =========================================================
# Servidor Web (UI con Tailwind)
# =========================================================
WEB_PORT=3000

# =========================================================
# Simulador local (npm run sim)
# =========================================================
SIM_PORT=5020
SIM_COILS=32

{
  "name": "modbus-luces-1b",
  "version": "1.0.0",
  "description": "Proyecto Node.js + TypeScript para controlar luces vía Modbus TCP, con simulador integrado para pruebas.",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "sim": "tsx src/simulator.ts",
    "sim:build": "node dist/simulator.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "modbus",
    "modbus-tcp",
    "iot",
    "automation",
    "typescript",
    "luces"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "modbus-serial": "^8.0.25",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
